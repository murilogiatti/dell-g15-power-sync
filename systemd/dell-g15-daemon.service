[Unit]
Description=Dell G15 Master Daemon (Power Profiles & Keyboard Sync)
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/g15-daemon.sh
Restart=always
RestartSec=5
# Garante que o script tenha acesso ao Display para notificações
Environment=DISPLAY=:0

[Install]
WantedBy=default.target
